{
  "name": "yimsg-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "check:guards": "node scripts/check-frontend-guards.mjs",
    "build:app": "npm run check:guards && tsc && vite build",
    "build": "npm run build:app && npm run build:uikit && npm run build:demo",
    "build:uikit": "tsc --noEmit && vite build --config vite.uikit.config.ts",
    "build:demo": "node scripts/copy-demo.mjs",
    "test:ui": "npx playwright test",
    "test:ui:headed": "npx playwright test --headed",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:sdk": "vitest run --config vitest.integration.config.ts"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "better-sqlite3": "^12.9.0",
    "grpc-tools": "^1.13.1",
    "jscpd": "^3.5.10",
    "ts-proto": "^2.11.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build9"
  }
}
